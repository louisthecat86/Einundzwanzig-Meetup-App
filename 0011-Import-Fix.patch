 import 'secure_key_store.dart';
 import 'platform_proof_service.dart'; // NEU
 import 'humanity_proof_service.dart'; // NEU
diff --git a/lib/services/humanity_proof_service.dart b/lib/services/humanity_proof_service.dart
index 230173e..8321f69 100644
--- a/lib/services/humanity_proof_service.dart
+++ b/lib/services/humanity_proof_service.dart
@@ -45,6 +45,7 @@ import 'package:shared_preferences/shared_preferences.dart';
