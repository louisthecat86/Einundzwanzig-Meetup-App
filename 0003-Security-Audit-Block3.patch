From bb509b6511638cdf5f025253c4f91dac55c14b41 Mon Sep 17 00:00:00 2001
From: SecurityAudit <audit@einundzwanzig.space>
Date: Thu, 26 Feb 2026 13:12:41 +0000
Subject: [PATCH] Security Audit Block 3: Final Hardening
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- M4: ALLE Subscription-IDs auf Random.secure() migriert (9 Services):
  admin_registry, promotion_claim_service, reputation_publisher,
  nip05_service, zap_verification_service, social_graph_service,
  humanity_proof_service (je 16 Hex-Zeichen statt Timestamp)
- M3: CI/CD Obfuscation aktiviert (--obfuscate --split-debug-info)
  + Debug-Symbole als separates Artifact für Crash-Analyse
---
 .github/workflows/build_apk.yml            | 11 +++++++++--
 lib/services/admin_registry.dart           |  6 +++++-
 lib/services/humanity_proof_service.dart   | 14 +++++++++++---
 lib/services/nip05_service.dart            |  6 +++++-
 lib/services/promotion_claim_service.dart  |  6 +++++-
 lib/services/reputation_publisher.dart     |  6 +++++-
 lib/services/social_graph_service.dart     |  6 +++++-
 lib/services/zap_verification_service.dart |  6 +++++-
 8 files changed, 50 insertions(+), 11 deletions(-)

diff --git a/.github/workflows/build_apk.yml b/.github/workflows/build_apk.yml
index 8ffb4b7..d35ea04 100644
--- a/.github/workflows/build_apk.yml
+++ b/.github/workflows/build_apk.yml
@@ -42,9 +42,9 @@ jobs:
         flutter clean
         flutter pub get
 
-    # 6. Bauen
+    # 6. Bauen (Security Audit M3: Obfuscation aktiviert)
     - name: Build APK
-      run: flutter build apk --release
+      run: flutter build apk --release --obfuscate --split-debug-info=build/debug-info
 
     # 7. Hochladen
     - name: Upload APK
@@ -52,3 +52,10 @@ jobs:
       with:
         name: einundzwanzig-app-release
         path: build/app/outputs/flutter-apk/app-release.apk
+
+    # 8. Debug-Symbole sichern (für Crash-Analyse)
+    - name: Upload Debug Symbols
+      uses: actions/upload-artifact@v4
+      with:
+        name: debug-symbols
+        path: build/debug-info/
