+          'Nächster Versuch beim nächsten App-Start.');
+        return false;
+      }
+    } catch (e) {
+      // Offline oder Relay-Fehler → nächstes Mal erneut versuchen
+      AppLogger.debug('HumanityProof', 'Reverifikation fehlgeschlagen (offline?): $e');
